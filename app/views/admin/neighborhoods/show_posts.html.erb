<%= stylesheet_link_tag 'chat_messages' %>

<%
  first_unread = nil
  unread_count = 0

  @posts.reverse.each do |m|
    if first_unread.nil? && @moderator_read && m.created_at >= @moderator_read.read_at
      first_unread = m
    end

    unread_count += 1 if first_unread
  end
%>
<div class="container">
  <%= render 'edit_header', tab: :show_posts %>

  <div class="row">
    <% if unread_count > 0 && first_unread %>
      <div class="conversation-unread-status" id="unreadStatus">
        <%= pluralize(unread_count, "nouveau message", "nouveaux messages") %>
        depuis le <%= l first_unread.created_at, format: "%-d %B %Y à %H h %M" %>
      </div>
    <% end %>

    <% color = {} %>
    <% color[current_user.id] || (color.count * 0.381966011 * 360).round %>
    <div class="conversation-message is-message-form">
      <div class="conversation-gutter">
        <div style="background-color: hsl(<%= color[current_user.id] %>, 70%, 75%)" class="conversation-icon">
          <%= [current_user.first_name.try(:first), current_user.last_name.try(:first)].compact.join.upcase %>
        </div>
      </div>

      <div class="conversation-content">
        <div>
          <%= link_to UserPresenter.new(user: current_user).display_name, admin_user_path(current_user), class: "conversation-sender" %>
        </div>
        <%= form_for ChatMessage.new, url: message_admin_neighborhood_path(@neighborhood.id) do |f| %>
          <%= f.text_area :content, class: "conversation-message-box", rows: 5 %>

          <div style="margin: 10px 0">
            <label style="margin-right: 15px">
              <%= radio_button_tag 'chat_message[scheduled]', '0', true, class: 'chat-message-scheduled-toggle' %> Envoyer maintenant
            </label>
            <label>
              <%= radio_button_tag 'chat_message[scheduled]', '1', false, class: 'chat-message-scheduled-toggle' %> Programmer
            </label>
          </div>

          <div id="chat-message-schedule-fields" class="row" style="display: none; margin-bottom: 10px">
            <div class="col-md-3">
              <%= label_tag 'chat_message_scheduled_date', 'Date' %>
              <%= date_field_tag 'chat_message[scheduled_date]', nil, class: 'form-control' %>
            </div>
            <div class="col-md-3">
              <%= label_tag 'chat_message_scheduled_time', 'Heure (heure de Paris)' %>
              <%= time_field_tag 'chat_message[scheduled_time]', nil, class: 'form-control' %>
            </div>
            <div class="col-md-3">
              <%= label_tag 'chat_message_recurrence_frequency', 'Récurrence' %>
              <%= select_tag 'chat_message[recurrence_frequency]', options_for_select([['Aucune', ''], ['Quotidienne', 'daily'], ['Hebdomadaire', 'weekly'], ['Mensuelle', 'monthly']]), class: 'form-control' %>
            </div>
            <div class="col-md-3">
              <%= label_tag 'chat_message_recurrence_ends_on', 'Fin de la récurrence' %>
              <%= date_field_tag 'chat_message[recurrence_ends_on]', nil, class: 'form-control' %>
            </div>
          </div>

          <%= f.submit 'Envoyer', class: "btn btn-primary", disabled: true, id: 'chat-message-submit' %>
        <% end %>
      </div>
    </div>

    <% if @scheduled_publications.present? %>
      <div class="panel panel-default" style="margin-top: 15px">
        <div class="panel-heading">Publications programmées</div>
        <ul class="list-group">
          <% @scheduled_publications.each do |scheduled_publication| %>
            <li class="list-group-item">
              <div><strong><%= l scheduled_publication.scheduled_at.in_time_zone('Paris'), format: "%A %-d %B %Y à %H h %M" %></strong></div>
              <div><%= truncate(scheduled_publication.publishable.content, length: 140) %></div>
              <div style="margin-top: 5px">
                <%= link_to "Éditer", edit_admin_scheduled_publication_path(scheduled_publication, return_to: show_posts_admin_neighborhood_path(@neighborhood)), class: "btn btn-default btn-xs" %>
                <%= link_to "Publier maintenant", publish_now_admin_scheduled_publication_path(scheduled_publication, return_to: show_posts_admin_neighborhood_path(@neighborhood)), method: :post, data: { confirm: "Publier ce post maintenant ?" }, class: "btn btn-default btn-xs" %>
                <% if scheduled_publication.recurring? %>
                  <%= link_to "Annuler cette occurrence", cancel_admin_scheduled_publication_path(scheduled_publication, scope: :occurrence, return_to: show_posts_admin_neighborhood_path(@neighborhood)), method: :post, data: { confirm: "Annuler cette occurrence ? La suivante restera programmée." }, class: "btn btn-danger btn-xs" %>
                  <%= link_to "Annuler la série", cancel_admin_scheduled_publication_path(scheduled_publication, scope: :series, return_to: show_posts_admin_neighborhood_path(@neighborhood)), method: :post, data: { confirm: "Annuler toute la série récurrente ?" }, class: "btn btn-danger btn-xs" %>
                <% else %>
                  <%= link_to "Annuler", cancel_admin_scheduled_publication_path(scheduled_publication, return_to: show_posts_admin_neighborhood_path(@neighborhood)), method: :post, data: { confirm: "Annuler cette publication programmée ?" }, class: "btn btn-danger btn-xs" %>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @posts.empty? %>
      Il n'y a pas encore de message.
    <% else %>
      <% date = nil %>

      <% @posts.each do |message| %>
        <% if date.nil? || date != message.created_at.to_date %>
          <% date = message.created_at.to_date %>
          <div class="conversation-day-divider">
            <div class="conversation-day-divider-label">
              <% if date == Date.today %>
                aujourd'hui
              <% else %>
                <%= l date, format: "%A %-d %B %Y" %>
              <% end %>
            </div>
          </div>
        <% end %>

        <% color[message.user_id] ||= (color.count * 0.381966011 * 360).round %>

        <div class="conversation-message">
          <div class="conversation-gutter">
            <div style="background-color: hsl(<%= color[message.user_id] %>, 70%, 75%)" class="conversation-icon">
              <%= [message.user.first_name.try(:first), message.user.last_name.try(:first)].compact.join.upcase %>
            </div>
          </div>
          <div class="conversation-content">
            <div>
              <%= link_to message.user.full_name, admin_user_path(message.user), class: "conversation-sender" %>
              <span class="conversation-timestamp"><%= l message.created_at, format: "%H h %M" %></span>
            </div>

            <%= chat_message_with_status(message) %>

            <% if message.survey.present? %>
              <p><strong>Sondage</strong></p>
              <div class="survey-choices">
                <% message.survey.choices.each_with_index do |choice, index| %>
                  <li><%= "#{choice} (#{message.survey.summary[index]} réponses)" %></li>
                <% end %>
              </div>
            <% end %>

            <% if message.image_path(true).present? %>
              <div id="chat-message-image-<%= message.id %>" style="margin-bottom: 15px">
                <%= image_tag(message.image_path(true), height: '100') %>
              </div>
            <% else %>
              <div id="chat-message-image-<%= message.id %>" hidden="hidden"></div>
            <% end %>

            <% if message.comments_count > 0 %>
              <div><%= link_to "voir les commentaires", show_post_comments_admin_neighborhood_path(@neighborhood, post_id: message.id) %></div>
            <% end %>
          </div>
          <div class="conversation-actions">
            <div class="dropdown" style="display: inline-block">
              <button class="btn btn-default dropdown-toggle" type="button" id="dropdownMenu1" data-toggle="dropdown" aria-haspopup="true" aria-expanded="true">
                <span class="caret"></span>
              </button>
              <ul class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenu1">
                <li>
                  <%= link_to "Marquer comme non lu",
                      unread_message_admin_neighborhoods_path(chat_message_id: message.id),
                      method: :post %>
                </li>

                <% unless message.comments_count > 0 %>
                  <li>
                    <%= link_to "Ajouter un commentaire", show_post_comments_admin_neighborhood_path(@neighborhood, post_id: message.id) %>
                  </li>
                <% end %>

                <li>
                  <%= link_to "Modifier la photo", edit_photo_admin_chat_message_path(message.id), remote: true %>
                </li>

                <li>
                  <%= link_to "Modifier le message", admin_chat_message_path(message.id), remote: true %>
                </li>

                <li>
                  <%= link_to "Supprimer le message",
                      destroy_message_admin_neighborhoods_path(chat_message_id: message.id),
                      method: :delete,
                      data: { confirm: "Voulez-vous vraiment supprimer ce message ? \n\n#{message.user.full_name} :\n#{message.content}" },
                      class: "text-danger" %>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <% if message == first_unread %>
          <div class="conversation-unread-divider" id="unreadDivider">
            <div class="conversation-unread-divider-label">messages déjà lus</div>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <div class="row">
      <%= paginate @posts %>
    </div>

    <% if @neighborhood.moderator_has_unread_content(user: current_user) %>
      <div class="text-center">
        <%= link_to "Marquer comme lu", read_all_messages_admin_neighborhood_path(@neighborhood), method: :post, class: "btn btn-default" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  $('[data-toggle="tooltip"]').tooltip()

  $(function(){
    var chatMessageSubmit = $('#new_chat_message [type=submit]')[0]
    $('#chat_message_content').on('input', function() {
      chatMessageSubmit.disabled = this.textLength === 0;
    })

    $('.chat-message-scheduled-toggle').on('change', function() {
      var scheduled = $('.chat-message-scheduled-toggle:checked').val() === '1'
      $('#chat-message-schedule-fields').toggle(scheduled)
      $('#chat-message-submit').val(scheduled ? 'Programmer' : 'Envoyer')
    })
  })
</script>
